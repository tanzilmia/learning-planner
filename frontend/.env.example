AUTH_SECRET=
# Google OAuth — same OAuth client IDs as BACKEND_GOOGLE_* / GOOGLE_* in backend/.env
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Alias (optional): AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET same as backend GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side base URL for Express API (used by proxy & sync route)
BACKEND_API_URL=http://localhost:5000/api
